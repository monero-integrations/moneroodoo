<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <!-- create payment method -->
        <record id="payment_method_monero_rpc" model="payment.method">
            <field name="name">XMR</field>
            <field name="code">monero_rpc</field>
            <field name="image" type="base64" file="monero_rpc_odoo/static/description/icon.png"/>
        </record>

        <!-- create payment provider and link the method + redirect form -->
        <record id="payment_provider_monero_rpc" model="payment.provider">
            <field name="name">Monero RPC</field>
            <field name="code">monero_rpc</field>
            <field name="is_cryptocurrency">True</field>
            <field name="image_128" type="base64"
                   file="monero_rpc_odoo/static/description/icon.png"/>
            <field name="company_id" ref="base.main_company"/>
            <field name="payment_method_ids" eval="[(4, ref('payment_method_monero_rpc'))]"/>
            <field name="state">enabled</field>
            <!-- Link the redirect form template so Odoo 19 JS can submit it -->
            <field name="redirect_form_view_id" ref="monero_rpc_odoo.monero_redirect_form"/>
            <field name="pre_msg">
            <![CDATA[<p>You will be redirected to the Payment information and processing page after clicking on the payment button.</p>]]>
            </field>
            <field name="pending_msg">
            <![CDATA[<p>Please pay the amount due to complete your order. </p>]]>
            </field>
            <field name="done_msg">
            <![CDATA[<p><b>
            Thanks for using XMR for payment.
            </b></p><br><p>Please note your order number for future reference.</p>]]>
            </field>

            <field name="num_confirmation_required">0</field>
            <field name="rpc_protocol">http</field>
            <field name="monero_rpc_config_host">127.0.0.1</field>
            <field name="monero_rpc_config_port">18082</field>
            <field name="monero_rpc_config_user">user</field>
            <field name="monero_rpc_config_password">password</field>
        </record>

    </data>
</odoo>
