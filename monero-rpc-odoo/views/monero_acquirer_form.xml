<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="provider_form_monero" model="ir.ui.view">
        <field name="name">payment.provider.form.inherit.payment.monero</field>
        <field name="model">payment.provider</field>
        <field name="inherit_id" ref="payment.payment_provider_form"/>
        <field name="arch" type="xml">
            <xpath expr='//group[@name="provider_credentials"]' position='inside'>
                <group invisible="code != 'monero_rpc'">
                    <field name="is_cryptocurrency" readonly="1" groups="base.group_no_one"/>
                    <field name="rpc_protocol"/>
                    <field name="monero_rpc_config_host"/>
                    <field name="monero_rpc_config_port"/>
                    <field name="monero_rpc_config_user"/>
                    <field name="monero_rpc_config_password"/>
                    <field name="type" readonly="1" string="Type" groups="base.group_no_one"/>
                    <field name="num_confirmation_required"/>
                </group>
            </xpath>
        </field>
    </record>
</odoo>
