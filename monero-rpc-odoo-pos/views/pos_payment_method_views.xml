<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="pos_payment_monero_method_view_list" model="ir.ui.view">
        <field name="name">pos.payment.method.list</field>
        <field name="model">pos.payment.method</field>
        <field name="arch" type="xml">
            <list string="Payment Methods">
                <field name="hide_use_payment_terminal" invisible="1"/>
                <field name="name" />
                <field name="receivable_account_id" groups="account.group_account_readonly"/>
                <field name="is_cash_count" />
                <field name="is_cryptocurrency" />
                <field name="split_transactions" groups="base.group_no_one" />
                <field name="use_payment_terminal" invisible="hide_use_payment_terminal" />
                <field name="company_id" groups="base.group_multi_company" />
            </list>
        </field>
    </record>

    <record id="action_payment_methods_list" model="ir.actions.act_window">
        <field name="context">{}</field>
        <field name="name">Payments Methods</field>
        <field name="res_model">pos.payment.method</field>
        <field name="view_id" ref="pos_payment_monero_method_view_list"/>
        <field name="view_mode">list,form,kanban</field>
    </record>
</odoo>
